{
  "name": "marvin",
  "version": "0.1.34",
  "private": true,
  "description": "Moderately Advanced Robotic Virtual Intelligence Network — pair-programming AI assistant.",
  "license": "MIT",
  "author": "Robert Ilisei",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "pnpm --filter @marvin/web start",
    "typecheck": "turbo run typecheck",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
