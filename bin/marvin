#!/usr/bin/env bash
# marvin — lifecycle script for the MARVIN dev server.
#
# Usage:
#   marvin [start|stop|restart|status|logs|doctor|help]
#
# Subcommands:
#   start    (default) — preflight checks, install deps if stale, start Next.js on :3030
#   stop     — stop the running MARVIN (matches the process bound to :3030)
#   restart  — stop + start
#   status   — is MARVIN running? hit /api/health, report auth mode + model
#   logs     — tail the dev server log
#   doctor   — run every preflight check and report; don't start anything
#   help     — this message
#
# Exit codes:
#   0  success
#   1  generic failure
#   2  preflight check failed (toolchain, credentials)
#   3  port conflict with a non-MARVIN process
#
# The script keeps a PID file at .marvin/pid and a log at .marvin/dev.log
# (both gitignored by MARVIN's own .gitignore). `pnpm dev` is what actually
# runs; this script is the professional wrapper with checks and lifecycle.

set -euo pipefail

# ─────────────────────────────────────────────────────────────────────
# Paths + constants

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

readonly PORT="${MARVIN_PORT:-3030}"
readonly STATE_DIR=".marvin"
readonly PID_FILE="$STATE_DIR/pid"
readonly LOG_FILE="$STATE_DIR/dev.log"
readonly MIN_NODE_MAJOR=22

mkdir -p "$STATE_DIR"

# ─────────────────────────────────────────────────────────────────────
# Pretty printing (colour only when stdout is a TTY)

if [ -t 1 ]; then
  C_RED=$'\033[31m'; C_GRN=$'\033[32m'; C_YEL=$'\033[33m'
  C_BLU=$'\033[34m'; C_DIM=$'\033[2m'; C_RST=$'\033[0m'
else
  C_RED=''; C_GRN=''; C_YEL=''; C_BLU=''; C_DIM=''; C_RST=''
fi

info()  { printf '%s%s%s %s\n' "$C_BLU" "ℹ" "$C_RST" "$*"; }
ok()    { printf '%s%s%s %s\n' "$C_GRN" "✓" "$C_RST" "$*"; }
warn()  { printf '%s%s%s %s\n' "$C_YEL" "!" "$C_RST" "$*"; }
fail()  { printf '%s%s%s %s\n' "$C_RED" "✗" "$C_RST" "$*" >&2; }
dim()   { printf '%s%s%s\n'    "$C_DIM" "$*"   "$C_RST"; }

# ─────────────────────────────────────────────────────────────────────
# Preflight checks — each returns 0 on pass, non-zero on fail.

check_node() {
  if ! command -v node >/dev/null 2>&1; then
    fail "node not found on PATH"
    dim "  install: https://nodejs.org  or  brew install node@${MIN_NODE_MAJOR}"
    return 2
  fi
  local version major
  version="$(node --version | sed 's/^v//')"
  major="${version%%.*}"
  if [ "$major" -lt "$MIN_NODE_MAJOR" ]; then
    fail "node $version is too old (need >= $MIN_NODE_MAJOR)"
    return 2
  fi
  ok "node v$version"
}

check_pnpm() {
  if ! command -v pnpm >/dev/null 2>&1; then
    fail "pnpm not found on PATH"
    dim "  install: npm install -g pnpm@10.33.0  (or use corepack)"
    return 2
  fi
  ok "pnpm $(pnpm --version)"
}

check_deps() {
  if [ ! -d node_modules ] || [ ! -f node_modules/.modules.yaml ]; then
    warn "node_modules missing — running pnpm install"
    pnpm install
  else
    ok "node_modules present"
  fi
}

check_skills() {
  if [ ! -d "$HOME/.claude/skills" ] || [ -z "$(ls -A "$HOME/.claude/skills" 2>/dev/null)" ]; then
    warn "no skills installed at ~/.claude/skills — running scripts/install-skills.sh"
    bash scripts/install-skills.sh
  else
    local count
    count="$(ls -1 "$HOME/.claude/skills" 2>/dev/null | wc -l | tr -d ' ')"
    ok "~/.claude/skills has $count skills installed"
  fi
}

check_claude_cli() {
  # MARVIN's Agent SDK spawns the `claude` binary under the hood — when
  # it's missing or unreachable, every turn fails with an opaque API
  # error forwarded from the spawned process. Surface the gap up front
  # instead of letting users hit it at runtime.
  #
  # Honours `MARVIN_CLAUDE_BIN` if set; otherwise looks on PATH. Advisory
  # only (warn, don't fail) — a user who exports the env var before
  # `bin/marvin` runs but after this check would still be fine, and
  # `/api/health` reports `binaryError` at runtime as a backstop.
  local bin="${MARVIN_CLAUDE_BIN:-claude}"
  if ! command -v "$bin" >/dev/null 2>&1; then
    warn "Claude Code CLI ('$bin') not found on PATH"
    dim "  install:  npm install -g @anthropic-ai/claude-code"
    dim "  or set MARVIN_CLAUDE_BIN=/path/to/claude before running marvin"
    dim "  MARVIN will start, but every turn will fail until this is fixed."
    return 0
  fi
  # A short --version probe also catches half-installed binaries (PATH
  # entry that segfaults, npm-link without the actual package, etc.).
  local version
  if ! version="$("$bin" --version 2>/dev/null | head -1)"; then
    warn "Claude Code CLI on PATH but '--version' failed — install may be broken"
    dim "  reinstall:  npm install -g @anthropic-ai/claude-code@latest"
    return 0
  fi
  ok "claude $version"
}

check_port() {
  if lsof -iTCP:"$PORT" -sTCP:LISTEN -t 2>/dev/null | grep -q .; then
    local pid; pid="$(lsof -iTCP:"$PORT" -sTCP:LISTEN -t 2>/dev/null | head -1)"
    if [ -f "$PID_FILE" ] && [ "$pid" = "$(cat "$PID_FILE")" ]; then
      # It's our own previous instance.
      ok "port $PORT already bound by MARVIN (pid $pid)"
      return 10  # sentinel — already-running
    fi
    fail "port $PORT is bound by a non-MARVIN process (pid $pid)"
    dim "  kill it:  kill $pid"
    return 3
  fi
  ok "port $PORT is free"
}

check_credentials() {
  # Warnings only; the Agent SDK will fail with a clear error at turn time
  # if auth is missing, and /api/health surfaces the detected mode.
  if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
    ok "ANTHROPIC_API_KEY in env"
    return 0
  fi
  if [ -f "$HOME/.claude/.credentials.json" ] || [ -f "$HOME/.claude/auth.json" ]; then
    ok "~/.claude/.credentials.json present"
    return 0
  fi
  if ls "$HOME/Library/Application Support/claude-cli/history.jsonl" >/dev/null 2>&1; then
    ok "macOS Keychain credentials (host-credentials mode)"
    return 0
  fi
  warn "no Anthropic credentials detected"
  dim "  set ANTHROPIC_API_KEY or run 'claude auth login'"
  dim "  MARVIN will start but /api/health will report ok:false"
  return 0
}

prefs_has_skip() {
  # Honour `.marvin/install-prefs.json` written by `scripts/setup.sh`
  # so deps the user explicitly marked "never" don't keep nagging on
  # every doctor / start. Returns 0 when the dep slug is in the
  # skipped list, 1 otherwise.
  local name="$1"
  local prefs="$STATE_DIR/install-prefs.json"
  [ -f "$prefs" ] || return 1
  node -e "
    const fs = require('fs');
    try {
      const p = JSON.parse(fs.readFileSync('$prefs','utf8'));
      const s = Array.isArray(p.skipped) ? p.skipped : [];
      process.exit(s.includes('$name') ? 0 : 1);
    } catch { process.exit(1); }
  " 2>/dev/null
}

check_chromium() {
  # Purely advisory — Playwright works without it, but marvin-playwright
  # MCP needs Chromium to drive localhost. Not a gate.
  if [ -d "$HOME/Library/Caches/ms-playwright" ] || [ -d "$HOME/.cache/ms-playwright" ]; then
    ok "Playwright Chromium installed (marvin-playwright MCP ready)"
  elif prefs_has_skip chromium; then
    dim "  Chromium skipped by user (delete $STATE_DIR/install-prefs.json to re-prompt)"
  else
    dim "  Chromium not installed — marvin-playwright MCP will be unavailable"
    dim "  install:  npx playwright install chromium  (or run scripts/setup.sh)"
  fi
  return 0
}

check_graphify() {
  # Advisory — graphify is the Python CLI users run to BUILD
  # graphify-out/graph.json. MARVIN reads the JSON directly (see
  # packages/graphify-bridge), so a missing graphify CLI is fine for
  # day-to-day code work; it just means the user can't refresh the
  # graph. `check_graph` separately validates the JSON itself.
  if command -v graphify >/dev/null 2>&1; then
    ok "graphify on PATH"
  elif prefs_has_skip graphify; then
    dim "  graphify skipped by user (delete $STATE_DIR/install-prefs.json to re-prompt)"
  else
    dim "  graphify (Python CLI) not on PATH — graph rebuilds will fail"
    dim "  install:  pipx install graphifyy  (or run scripts/setup.sh)"
  fi
  return 0
}

check_graph() {
  # Audit finding #1: the graph at graphify-out/graph.json was built
  # against a different repo (J.A.R.V.I.S nodes), silently disabling
  # Golden Rule 7 — every `marvin-graph` MCP query MARVIN's loop
  # makes returns answers about a different codebase.
  #
  # Smoke check: read graph.json, look for at least one node whose
  # source_file starts with `apps/` or `packages/` (MARVIN's own
  # workspace dirs). If the graph is missing, advise on rebuild. If
  # it's present but mis-rooted, warn — the user runs the rebuild
  # locally because `graphify` itself isn't shipped here.
  #
  # Advisory only (no `return 1`). The CLI still starts; users who
  # know what they're doing can dismiss.
  local graph="$REPO_ROOT/graphify-out/graph.json"
  if [ ! -f "$graph" ]; then
    warn "graphify-out/graph.json missing — Golden Rule 7 graph queries will fail"
    dim "  rebuild: graphify . --rebuild   (from ${REPO_ROOT})"
    return 0
  fi

  # node -e is the path of least resistance: jq isn't a hard dep,
  # and we already require Node ≥ 22 for the rest of MARVIN.
  if ! node -e "
    const fs = require('fs');
    let g;
    try { g = JSON.parse(fs.readFileSync('$graph','utf8')); }
    catch (e) { process.exit(2); }
    const nodes = g.nodes || [];
    const total = nodes.length;
    // Accept either relative MARVIN paths (apps/ packages/ docs/ bin/
    // scripts/) OR absolute paths that contain '/marvin/' — graphify
    // emits both shapes depending on extraction mode. Root-level config
    // files (vitest.config.ts, biome.json) are unrooted by this rule
    // but they make up <1% of nodes and the threshold absorbs them.
    const rooted = nodes.filter(n => {
      const sf = typeof n.source_file === 'string' ? n.source_file : '';
      if (!sf) return false;
      if (/^(apps|packages|docs|bin|scripts)\//.test(sf)) return true;
      if (sf.includes('/marvin/')) return true;
      return false;
    }).length;
    if (total === 0) process.exit(3);
    // Require at least 5% of nodes to be MARVIN-rooted. The threshold
    // is generous on purpose — even a small slice of foreign nodes is
    // fine, but a graph with zero MARVIN nodes (the audit-day state)
    // means the rebuild ran in the wrong directory.
    const ratio = rooted / total;
    if (ratio < 0.05) process.exit(4);
    console.error('  ' + total + ' nodes · ' + rooted + ' rooted in MARVIN (' + (ratio*100).toFixed(0) + '%)');
    process.exit(0);
  " 2>/tmp/marvin-graph-check.log; then
    local code=$?
    case "$code" in
      2) warn "graphify-out/graph.json is unreadable JSON — rebuild required" ;;
      3) warn "graphify-out/graph.json has zero nodes — rebuild required" ;;
      4) warn "graphify-out/graph.json is mis-rooted — <5% of nodes are MARVIN's. Rebuild from ${REPO_ROOT}." ;;
      *) warn "graph smoke check failed (exit $code)" ;;
    esac
    dim "  rebuild: graphify . --rebuild   (from ${REPO_ROOT})"
    rm -f /tmp/marvin-graph-check.log
    return 0
  fi
  ok "graphify graph rooted in MARVIN ($(cat /tmp/marvin-graph-check.log 2>/dev/null | tr -d '\n' || echo 'ok'))"
  rm -f /tmp/marvin-graph-check.log
  return 0
}

preflight() {
  info "preflight checks"
  check_node || return $?
  check_pnpm || return $?
  check_deps || return $?
  check_skills || return $?
  check_claude_cli || return $?
  check_credentials || return $?
  check_chromium || return $?
  check_graphify || return $?
  check_graph || return $?
  check_port
  local port_status=$?
  return $port_status
}

# ─────────────────────────────────────────────────────────────────────
# Lifecycle

cmd_doctor() {
  preflight || true
  echo
  info "doctor pass complete"
}

# Decide whether `apps/web/.next` (the production build artefact) is
# present and not stale relative to source. "Stale" = source files
# under apps/web/src or packages/* are newer than the build manifest.
# Returns 0 when a usable build exists, 1 when a (re)build is needed.
build_is_fresh() {
  local manifest="apps/web/.next/build-manifest.json"
  [ -f "$manifest" ] || return 1
  # If anything under tracked source dirs is newer than the manifest, rebuild.
  # `find -newer` does the comparison; `-print -quit` exits at the first hit.
  local newer
  newer="$(find apps/web/src apps/web/next.config.ts packages/*/src \
    -type f -newer "$manifest" -print -quit 2>/dev/null || true)"
  [ -z "$newer" ]
}

cmd_start() {
  local mode="${MARVIN_MODE:-prod}"
  info "starting MARVIN on port $PORT (mode: $mode)"

  preflight
  local pf=$?
  if [ $pf -eq 10 ]; then
    warn "MARVIN already running — nothing to do"
    dim "  open http://localhost:$PORT  or  run:  $0 restart"
    return 0
  fi
  if [ $pf -ne 0 ]; then
    fail "preflight failed (exit $pf) — aborting"
    return $pf
  fi

  # In prod mode, ensure a fresh build exists before starting.
  # Audit finding: `next dev` is 5–10× slower than `next start`; the
  # default launch should serve production. Use `marvin dev` for
  # explicit dev mode (HMR, source maps, slower).
  local run_cmd="pnpm start"
  if [ "$mode" = "dev" ]; then
    run_cmd="pnpm dev"
  else
    if build_is_fresh; then
      ok "build is fresh — skipping rebuild"
    else
      info "production build is stale or missing — running 'pnpm build'"
      if pnpm build >>"$LOG_FILE" 2>&1; then
        ok "build complete"
      else
        fail "build failed — see $LOG_FILE for details"
        dim "  workaround: run with dev mode → MARVIN_MODE=dev $0 start  (or)  $0 dev"
        return 1
      fi
    fi
  fi

  info "spawning '$run_cmd' (output → $LOG_FILE)"
  # nohup so the server keeps running if this shell exits.
  # setsid keeps it in a new process group so `stop` can kill cleanly.
  nohup env MARVIN_PORT="$PORT" $run_cmd >"$LOG_FILE" 2>&1 &
  local pid=$!
  echo "$pid" >"$PID_FILE"
  ok "spawned pid $pid"

  # Wait up to 30s for /api/health to respond
  info "waiting for /api/health …"
  local n=0
  while [ $n -lt 30 ]; do
    if curl -sf "http://localhost:$PORT/api/health" >/dev/null 2>&1; then
      local body; body="$(curl -sf "http://localhost:$PORT/api/health" 2>/dev/null || echo '{}')"
      local mode model
      mode="$(printf '%s' "$body" | sed -n 's/.*"mode":"\([^"]*\)".*/\1/p')"
      model="$(printf '%s' "$body" | sed -n 's/.*"defaultModel":"\([^"]*\)".*/\1/p')"
      echo
      ok "MARVIN is up"
      printf '  %-12s %s\n' "URL:"   "http://localhost:$PORT"
      printf '  %-12s %s\n' "auth:"  "${mode:-unknown}"
      printf '  %-12s %s\n' "model:" "${model:-unknown}"
      printf '  %-12s %s (pid $pid)\n' "logs:"  "tail -f $LOG_FILE"
      return 0
    fi
    printf '.' ; n=$((n + 1)) ; sleep 1
  done
  echo
  fail "server did not respond to /api/health within 30s"
  dim "  last log lines:"
  tail -20 "$LOG_FILE" | sed 's/^/    /'
  return 1
}

cmd_stop() {
  if [ ! -f "$PID_FILE" ]; then
    warn "no pid file — is MARVIN running?"
    # Best-effort port-bound kill in case the pid file is missing.
    local pid; pid="$(lsof -iTCP:"$PORT" -sTCP:LISTEN -t 2>/dev/null | head -1 || true)"
    if [ -n "$pid" ]; then
      info "found process on port $PORT (pid $pid) — killing"
      kill "$pid" 2>/dev/null || true
      sleep 1
      kill -9 "$pid" 2>/dev/null || true
      ok "stopped"
    fi
    return 0
  fi

  local pid; pid="$(cat "$PID_FILE")"
  if ! kill -0 "$pid" 2>/dev/null; then
    warn "pid $pid in pidfile is not running — cleaning up"
    rm -f "$PID_FILE"
    return 0
  fi

  info "stopping MARVIN (pid $pid)"
  # Kill the whole process group so pnpm + next + turbopack all go together.
  kill -TERM "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true
  sleep 2
  if kill -0 "$pid" 2>/dev/null; then
    warn "didn't exit on SIGTERM — sending SIGKILL"
    kill -KILL "-$pid" 2>/dev/null || kill -KILL "$pid" 2>/dev/null || true
  fi
  rm -f "$PID_FILE"
  ok "stopped"
}

cmd_restart() {
  cmd_stop || true
  sleep 1
  cmd_start
}

cmd_status() {
  if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    local pid; pid="$(cat "$PID_FILE")"
    ok "MARVIN running (pid $pid)"
  else
    local port_pid; port_pid="$(lsof -iTCP:"$PORT" -sTCP:LISTEN -t 2>/dev/null | head -1 || true)"
    if [ -n "$port_pid" ]; then
      warn "port $PORT bound by pid $port_pid but no MARVIN pidfile — foreign process?"
    else
      warn "MARVIN is not running"
      return 1
    fi
  fi

  if ! curl -sf "http://localhost:$PORT/api/health" >/dev/null 2>&1; then
    fail "MARVIN is up but /api/health is not responding"
    return 1
  fi

  local body; body="$(curl -sf "http://localhost:$PORT/api/health" 2>/dev/null || echo '{}')"
  local mode credhint model datadir
  mode="$(printf '%s' "$body"     | sed -n 's/.*"mode":"\([^"]*\)".*/\1/p')"
  credhint="$(printf '%s' "$body" | sed -n 's/.*"credentialHint":"\([^"]*\)".*/\1/p')"
  model="$(printf '%s' "$body"    | sed -n 's/.*"defaultModel":"\([^"]*\)".*/\1/p')"
  datadir="$(printf '%s' "$body"  | sed -n 's/.*"dataDir":"\([^"]*\)".*/\1/p')"

  printf '  %-14s %s\n' "URL:"     "http://localhost:$PORT"
  printf '  %-14s %s\n' "auth:"    "${mode:-unknown}"
  [ -n "$credhint" ] && printf '  %-14s %s\n' "credentials:" "$credhint"
  printf '  %-14s %s\n' "model:"   "${model:-unknown}"
  printf '  %-14s %s\n' "data dir:" "${datadir:-unknown}"
  printf '  %-14s %s\n' "logs:"    "tail -f $LOG_FILE"
}

cmd_logs() {
  if [ ! -f "$LOG_FILE" ]; then
    fail "no log file at $LOG_FILE — is MARVIN running?"
    return 1
  fi
  exec tail -f -n 100 "$LOG_FILE"
}

# ─────────────────────────────────────────────────────────────────────
# macOS .app install flow (ADR-0010 v1 compromise + launchd agent).
#
# MARVIN's Tauri `.app` is a thin window pointed at http://localhost:3030.
# The window itself doesn't start the Next.js server — ADR-0011 tried to
# bundle a Node sidecar and got rolled back (binary size, code-signing
# churn, runtime drift). The pragmatic compromise: install a launchd
# user agent that keeps `pnpm dev` running in the background. The
# `.app` then works as a double-click launcher, no terminal needed.
#
# `install-app` builds the `.app`, copies it to /Applications/, and
# installs the launchd plist. `uninstall-app` reverses both. The plist
# binds absolute paths at install time — moving the MARVIN source
# means re-running install.

readonly APP_NAME="MARVIN"
readonly APP_BUNDLE_DIR="/Applications/${APP_NAME}.app"
readonly AGENT_LABEL="net.marvin.desktop.server"
readonly AGENT_PLIST="$HOME/Library/LaunchAgents/${AGENT_LABEL}.plist"
readonly BUILT_APP_PATH="apps/desktop/src-tauri/target/release/bundle/macos/${APP_NAME}.app"

cmd_install_app() {
  info "installing ${APP_NAME} as a macOS app"

  # Preflight — need Rust + build tools. If Cargo isn't on PATH, try
  # sourcing the default install location so users don't have to
  # remember `. $HOME/.cargo/env` every time.
  if ! command -v cargo >/dev/null 2>&1; then
    if [ -f "$HOME/.cargo/env" ]; then
      # shellcheck disable=SC1091
      . "$HOME/.cargo/env"
    fi
  fi
  if ! command -v cargo >/dev/null 2>&1; then
    fail "cargo not found — Tauri needs the Rust toolchain"
    dim "  install with:  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y"
    return 2
  fi

  local pnpm_abs
  pnpm_abs="$(command -v pnpm)" || {
    fail "pnpm not found on PATH — can't create the launchd agent"
    return 2
  }

  info "building .app (this takes a minute on a cold Cargo cache)"
  if ! pnpm --filter @marvin/desktop build >"$STATE_DIR/desktop-build.log" 2>&1; then
    fail "build failed — see $STATE_DIR/desktop-build.log"
    tail -20 "$STATE_DIR/desktop-build.log" | sed 's/^/    /'
    return 1
  fi
  ok "built $BUILT_APP_PATH"

  if [ ! -d "$BUILT_APP_PATH" ]; then
    fail "build completed but ${APP_NAME}.app not found at expected path"
    dim "  expected: $REPO_ROOT/$BUILT_APP_PATH"
    return 1
  fi

  # Copy into /Applications. The rm-then-cp avoids "source inside
  # destination" issues on repeat installs. /Applications is writable
  # without sudo for the current user on most modern macOS setups;
  # if it isn't we'll get a clear permission error.
  info "installing to $APP_BUNDLE_DIR"
  if [ -d "$APP_BUNDLE_DIR" ]; then
    rm -rf "$APP_BUNDLE_DIR" || {
      fail "couldn't remove previous $APP_BUNDLE_DIR — try: sudo rm -rf $APP_BUNDLE_DIR"
      return 1
    }
  fi
  cp -R "$BUILT_APP_PATH" "$APP_BUNDLE_DIR" || {
    fail "copy to /Applications failed — permissions?"
    return 1
  }
  ok "installed ${APP_NAME}.app"

  # Passthrough env vars. The running server needs credentials +
  # telemetry config to work without the user later hunting through a
  # shell. An explicit allowlist is intentional — we don't want to
  # smuggle arbitrary shell state into a launch agent. If any of these
  # are set in the installing shell, they get baked into the plist.
  #
  # Primary path for Honeycomb telemetry is still the Settings UI
  # (MARVIN auto-exports OTEL vars from saved config at turn-start),
  # so most users never need this. It exists for the advanced case
  # where a user already drives telemetry via shell env vars.
  local -a passthrough_keys=(
    CLAUDE_CODE_ENABLE_TELEMETRY
    OTEL_METRICS_EXPORTER
    OTEL_LOGS_EXPORTER
    OTEL_EXPORTER_OTLP_PROTOCOL
    OTEL_EXPORTER_OTLP_ENDPOINT
    OTEL_EXPORTER_OTLP_HEADERS
    OTEL_SERVICE_NAME
    OTEL_RESOURCE_ATTRIBUTES
    HONEYCOMB_API_KEY
    HONEYCOMB_ENVIRONMENT
    HONEYCOMB_DATASET
    HONEYCOMB_API_URL
    ANTHROPIC_API_KEY
    CLAUDE_CODE_OAUTH_TOKEN
    MARVIN_USE_HOST_CREDENTIALS
  )
  local passthrough_env_xml=""
  local passthrough_count=0
  local key val val_escaped
  for key in "${passthrough_keys[@]}"; do
    val="${!key:-}"
    [ -n "$val" ] || continue
    # XML-escape the value — & < > are the only ones that matter
    # inside a <string> node.
    val_escaped=$(printf '%s' "$val" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g')
    passthrough_env_xml+="
    <key>${key}</key>
    <string>${val_escaped}</string>"
    passthrough_count=$((passthrough_count + 1))
  done
  if [ "$passthrough_count" -gt 0 ]; then
    dim "  passing through $passthrough_count env var(s) from the installing shell"
  fi

  # Write the launchd user agent plist. Bakes in absolute paths for
  # pnpm + REPO_ROOT so launchd doesn't need PATH-discovery. If the
  # user moves either, they re-run install-app.
  info "installing launchd agent → $AGENT_PLIST"
  mkdir -p "$(dirname "$AGENT_PLIST")"
  cat >"$AGENT_PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${AGENT_LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${pnpm_abs}</string>
    <string>dev</string>
  </array>
  <key>WorkingDirectory</key>
  <string>${REPO_ROOT}</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>${PATH}</string>
    <key>HOME</key>
    <string>${HOME}</string>
    <key>MARVIN_PORT</key>
    <string>${PORT}</string>${passthrough_env_xml}
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>NetworkState</key>
    <true/>
  </dict>
  <key>StandardOutPath</key>
  <string>${REPO_ROOT}/${STATE_DIR}/launchd-stdout.log</string>
  <key>StandardErrorPath</key>
  <string>${REPO_ROOT}/${STATE_DIR}/launchd-stderr.log</string>
</dict>
</plist>
PLIST
  ok "wrote agent plist"

  # Unload any previous instance (idempotent install), then load.
  launchctl unload "$AGENT_PLIST" 2>/dev/null || true
  if ! launchctl load "$AGENT_PLIST" 2>/dev/null; then
    fail "launchctl load failed — try: launchctl load $AGENT_PLIST"
    return 1
  fi
  ok "launchd agent loaded"

  # Give the agent a few seconds to boot before we claim success.
  info "waiting for server to come up on :$PORT"
  local n=0
  while [ $n -lt 30 ]; do
    if curl -sf "http://localhost:$PORT/api/health" >/dev/null 2>&1; then
      echo
      ok "${APP_NAME} installed and running"
      printf '  %-16s %s\n' "app:"     "$APP_BUNDLE_DIR"
      printf '  %-16s %s\n' "agent:"   "$AGENT_PLIST"
      printf '  %-16s %s\n' "server:"  "http://localhost:$PORT"
      printf '  %-16s %s\n' "logs:"    "${REPO_ROOT}/${STATE_DIR}/launchd-stderr.log"
      echo
      dim "  open via Spotlight / Launchpad / Dock — double-click ${APP_NAME}"
      dim "  uninstall: $0 uninstall-app"
      return 0
    fi
    printf '.' ; n=$((n + 1)) ; sleep 1
  done
  echo
  warn "server didn't respond within 30s — the launchd agent is loaded but may still be compiling"
  dim "  tail the logs:  tail -f ${REPO_ROOT}/${STATE_DIR}/launchd-stderr.log"
  return 0
}

readonly MACOS_APP_NAME="MARVIN-Swift"
readonly MACOS_APP_BUNDLE_DIR="/Applications/${MACOS_APP_NAME}.app"

cmd_install_macos_app() {
  # Builds the SwiftUI native target at apps/macos/ and installs the
  # resulting `.app` bundle to /Applications/. Phase 1a uses ad-hoc
  # signing — Gatekeeper warns on first open (right-click → Open).
  # Real Developer ID + notarization gets wired at the end of Phase 1
  # once a signing identity is plumbed in. See ADR-0016.
  #
  # Installs as MARVIN-Swift.app — distinct from the Tauri MARVIN.app
  # at /Applications/MARVIN.app, so both coexist during the migration
  # evaluation period. Phase 6 (Tauri retire) renames to MARVIN.app.
  #
  # Two build paths, picked by what's installed:
  #   • xcodebuild + xcodegen (preferred) — produces a real Xcode
  #     build with all the warnings, scheme/configuration options,
  #     and the eventual signing/notarization wiring.
  #   • swift build (fallback) — works with just the Command Line
  #     Tools (no full Xcode). Manually assembles the .app bundle
  #     from the SPM executable + a substituted Info.plist. Same
  #     binary semantics, simpler dev loop, no signing identity.
  info "installing ${MACOS_APP_NAME} (SwiftUI / Phase 1a)"

  local macos_dir="$REPO_ROOT/apps/macos"
  if [ ! -f "$macos_dir/project.yml" ]; then
    fail "$macos_dir/project.yml missing — Phase 0 not scaffolded?"
    return 1
  fi

  # Pick the build path. xcodebuild only counts as "available" if it
  # actually runs (CLT installs ship a stub that errors out).
  local use_spm=0
  if command -v xcodebuild >/dev/null 2>&1 && xcodebuild -version >/dev/null 2>&1; then
    if ! command -v xcodegen >/dev/null 2>&1; then
      warn "xcodebuild available but xcodegen is missing — falling back to swift build"
      dim "  to use xcodebuild:  brew install xcodegen"
      use_spm=1
    fi
  else
    use_spm=1
  fi

  local built_app
  if [ "$use_spm" -eq 0 ]; then
    info "regenerating MARVIN.xcodeproj from project.yml"
    ( cd "$macos_dir" && xcodegen generate ) || {
      fail "xcodegen failed"
      return 1
    }
    info "running xcodebuild (Release)"
    local derived="$macos_dir/build"
    ( cd "$macos_dir" && xcodebuild \
        -project MARVIN.xcodeproj \
        -scheme MARVIN \
        -configuration Release \
        -derivedDataPath "$derived" \
        -quiet \
        build ) || {
      fail "xcodebuild failed"
      dim "  re-run without -quiet to see the full output"
      return 1
    }
    built_app="$derived/Build/Products/Release/${MACOS_APP_NAME}.app"
    if [ ! -d "$built_app" ]; then
      fail "build succeeded but ${MACOS_APP_NAME}.app is missing at $built_app"
      return 1
    fi
  else
    if ! command -v swift >/dev/null 2>&1; then
      fail "neither xcodebuild nor swift found — install Xcode or the Swift toolchain"
      return 2
    fi
    info "no Xcode — using swift build + manual bundle assembly"
    ( cd "$macos_dir" && swift build -c release ) || {
      fail "swift build failed"
      return 1
    }
    local exe="$macos_dir/.build/release/MARVIN"
    if [ ! -x "$exe" ]; then
      fail "swift build succeeded but $exe is missing"
      return 1
    fi
    info "assembling ${MACOS_APP_NAME}.app"
    local stage="$macos_dir/build-spm"
    rm -rf "$stage"
    built_app="$stage/${MACOS_APP_NAME}.app"
    mkdir -p "$built_app/Contents/MacOS" "$built_app/Contents/Resources"
    cp "$exe" "$built_app/Contents/MacOS/${MACOS_APP_NAME}"
    chmod +x "$built_app/Contents/MacOS/${MACOS_APP_NAME}"
    # Substitute Xcode-style template tokens in the source Info.plist
    # so the bundle resolves cleanly without xcodebuild.
    sed \
      -e "s|\$(EXECUTABLE_NAME)|${MACOS_APP_NAME}|g" \
      -e "s|\$(PRODUCT_BUNDLE_IDENTIFIER)|net.marvin.macos|g" \
      -e "s|\$(PRODUCT_NAME)|${MACOS_APP_NAME}|g" \
      "$macos_dir/MARVIN/Info.plist" > "$built_app/Contents/Info.plist"
    # Bundle the Brain Circuit icon — SPM doesn't carry the .icns
    # itself, so we copy it (and the source SVGs, for menu-bar
    # template use down the line) directly into Contents/Resources.
    if [ -f "$macos_dir/MARVIN/Resources/AppIcon.icns" ]; then
      cp "$macos_dir/MARVIN/Resources/AppIcon.icns" "$built_app/Contents/Resources/"
    else
      warn "AppIcon.icns missing — run scripts/build-app-icon.sh to regenerate"
    fi
    for svg in "$macos_dir/MARVIN/Resources"/*.svg; do
      [ -f "$svg" ] && cp "$svg" "$built_app/Contents/Resources/"
    done
    info "ad-hoc signing"
    codesign --force --deep --sign - "$built_app" >/dev/null 2>&1 || {
      fail "codesign failed"
      return 1
    }
  fi
  ok "built $built_app"

  info "copying to /Applications"
  # Don't nuke /Applications/MARVIN.app — that's the Tauri build.
  # Only replace MARVIN-Swift.app.
  rm -rf "$MACOS_APP_BUNDLE_DIR"
  cp -R "$built_app" "$MACOS_APP_BUNDLE_DIR"
  ok "installed at $MACOS_APP_BUNDLE_DIR"

  echo
  dim "  open with:  open '$MACOS_APP_BUNDLE_DIR'"
  dim "  Phase 1a polls /api/health on port $PORT — start the sidecar first:"
  dim "    $0 start"
  dim "  Gatekeeper note: ad-hoc signed; right-click → Open on first launch."
}

cmd_uninstall_app() {
  info "uninstalling ${APP_NAME}"

  if [ -f "$AGENT_PLIST" ]; then
    launchctl unload "$AGENT_PLIST" 2>/dev/null || true
    rm -f "$AGENT_PLIST"
    ok "removed launchd agent"
  else
    dim "  no launchd agent at $AGENT_PLIST"
  fi

  if [ -d "$APP_BUNDLE_DIR" ]; then
    rm -rf "$APP_BUNDLE_DIR"
    ok "removed $APP_BUNDLE_DIR"
  else
    dim "  no ${APP_NAME}.app at $APP_BUNDLE_DIR"
  fi

  ok "uninstall complete"
  dim "  source tree + ~/.marvin/ left alone; rm them by hand if you want"
}

cmd_help() {
  cat <<'EOF'
marvin — lifecycle script for the MARVIN dev server

  marvin              (alias for start)
  marvin start        preflight + production build (if stale) + 'next start'
  marvin dev          preflight + 'next dev' — HMR, source maps, ~5–10× slower
                      (use this when iterating on MARVIN's own UI)
  marvin stop         stop the running instance
  marvin restart      stop + start (production mode)
  marvin status       is it running? show auth + model + data dir
  marvin logs         tail the dev server log
  marvin doctor       run every preflight check, don't start anything

macOS .app (double-click-to-launch install flow):

  marvin install-app        build Tauri .app (ADR-0010), copy to
                            /Applications, install launchd agent so
                            the sidecar auto-starts on login
  marvin install-macos-app  build SwiftUI .app (ADR-0016, Phase 1a),
                            copy to /Applications/MARVIN-Swift.app
                            (distinct from the Tauri MARVIN.app). Uses
                            xcodebuild + xcodegen if Xcode is
                            installed, otherwise falls back to
                            `swift build` + manual bundle assembly.
                            No launchd agent — start the sidecar with
                            `marvin start` separately.
  marvin uninstall-app      remove the .app + launchd agent

  marvin help           this message

Environment:
  MARVIN_PORT         override the port (default 3030)
  MARVIN_DATA_DIR     where MARVIN keeps its runtime state (default ~/.marvin/)
  ANTHROPIC_API_KEY   direct API key; wins over host credentials

State:
  .marvin/pid                 pid of the live instance
  .marvin/dev.log             dev server stdout/stderr
  .marvin/launchd-stderr.log  launchd agent log (macOS install)
EOF
}

# ─────────────────────────────────────────────────────────────────────
# Dispatch

case "${1:-start}" in
  start)    cmd_start   ;;
  dev)      MARVIN_MODE=dev cmd_start ;;
  stop)     cmd_stop    ;;
  restart)  cmd_restart ;;
  status)   cmd_status  ;;
  logs)     cmd_logs    ;;
  doctor)   cmd_doctor  ;;
  install-app)        cmd_install_app       ;;
  install-macos-app)  cmd_install_macos_app ;;
  uninstall-app)      cmd_uninstall_app     ;;
  help|-h|--help)  cmd_help ;;
  *)
    fail "unknown subcommand: $1"
    echo
    cmd_help
    exit 1
    ;;
esac
