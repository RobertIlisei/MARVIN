{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MARVIN",
  "version": "1.0.0",
  "identifier": "net.marvin.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3030",
    "frontendDist": "http://localhost:3030"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "MARVIN",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "url": "http://localhost:3030"
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns"],
    "category": "DeveloperTool",
    "shortDescription": "MARVIN — pair-programming AI assistant",
    "longDescription": "Moderately Advanced Robotic Virtual Intelligence Network. MARVIN is a single-assistant pair-programming tool — chat, edit, diff, and confirm directly against your project, with a knowledge graph and cost tracker baked in.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "dmg": {
        "windowSize": { "width": 540, "height": 380 }
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
